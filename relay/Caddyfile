{
	email {$LE_EMAIL}
}

{$RELAY_DOMAIN} {
	encode gzip

	# CORS headers — set at the Caddy layer so they're present on
	# Caddy-generated error responses too. When uvicorn is down, Caddy
	# returns a 502 without ever calling FastAPI, and without these
	# headers the browser blocks the response with a CORS error before
	# the JS catch handler can see the failure. The PWA then
	# misinterprets "relay down" as a CORS issue.
	@from_pwa header Origin {$CORS_ORIGIN}
	header @from_pwa Access-Control-Allow-Origin "{$CORS_ORIGIN}"
	header @from_pwa Access-Control-Allow-Methods "GET, POST, PUT, OPTIONS"
	header @from_pwa Access-Control-Allow-Headers "Content-Type, X-Token, Authorization"
	# Cache the preflight verdict client-side: /status now carries X-Token
	# (non-simple GET), and without this every 8 s PWA poll would pay an
	# extra OPTIONS round-trip (browsers default to ~5 s preflight cache).
	# Browsers cap the value anyway (Chrome 2 h, Firefox 24 h).
	header @from_pwa Access-Control-Max-Age "86400"
	header @from_pwa Vary "Origin"

	# Handle OPTIONS preflight at the Caddy level so it succeeds even
	# when uvicorn is unavailable (FastAPI normally answers preflights,
	# but only if it's actually reachable).
	@options method OPTIONS
	handle @options {
		respond "" 204
	}

	# Sanitize the client IP before it reaches uvicorn. Caddy APPENDS the
	# peer IP to any client-supplied X-Forwarded-For, so the leftmost value
	# is attacker-controlled. Strip inbound XFF and set X-Real-IP from
	# Caddy's own view of the connecting peer ({remote_host}) — the only
	# value an external client cannot forge. app.py reads X-Real-IP for the
	# rate limiter + audit log. Without this, a rotating spoofed XFF bypasses
	# the per-IP /wol rate limit and poisons the audit log.
	# Pock sync — per-app JSON blob store (Jqh63/pock, sync/), third service
	# on this VM. Path route on the same vhost (no new vhost/cert); every
	# other path still falls through to the relay below. Same X-Real-IP
	# sanitization (its rate limiter keys on it too).
	handle /pock/* {
		reverse_proxy localhost:8001 {
			header_up -X-Forwarded-For
			header_up X-Real-IP {remote_host}
		}
	}

	reverse_proxy localhost:8000 {
		header_up -X-Forwarded-For
		header_up X-Real-IP {remote_host}
	}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}
}
