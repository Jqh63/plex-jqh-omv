{
	email {$LE_EMAIL}
}

{$RELAY_DOMAIN} {
	encode gzip

	# CORS headers — set at the Caddy layer so they're present on
	# Caddy-generated error responses too. When uvicorn is down, Caddy
	# returns a 502 without ever calling FastAPI, and without these
	# headers the browser blocks the response with a CORS error before
	# the JS catch handler can see the failure. The PWA then
	# misinterprets "relay down" as a CORS issue.
	@from_pwa header Origin {$CORS_ORIGIN}
	header @from_pwa Access-Control-Allow-Origin "{$CORS_ORIGIN}"
	header @from_pwa Access-Control-Allow-Methods "GET, POST, PUT, OPTIONS"
	header @from_pwa Access-Control-Allow-Headers "Content-Type, X-Token, X-Client-Id, Authorization"
	# Cache the preflight verdict client-side: /status now carries X-Token
	# (non-simple GET), and without this every 8 s PWA poll would pay an
	# extra OPTIONS round-trip (browsers default to ~5 s preflight cache).
	# Browsers cap the value anyway (Chrome 2 h, Firefox 24 h).
	header @from_pwa Access-Control-Max-Age "86400"
	header @from_pwa Vary "Origin"

	# Handle OPTIONS preflight at the Caddy level so it succeeds even
	# when uvicorn is unavailable (FastAPI normally answers preflights,
	# but only if it's actually reachable).
	@options method OPTIONS
	handle @options {
		respond "" 204
	}

	# Sanitize the client IP before it reaches uvicorn. Caddy APPENDS the
	# peer IP to any client-supplied X-Forwarded-For, so the leftmost value
	# is attacker-controlled. Strip inbound XFF and set X-Real-IP from
	# Caddy's own view of the connecting peer ({remote_host}) — the only
	# value an external client cannot forge. app.py reads X-Real-IP for the
	# rate limiter + audit log. Without this, a rotating spoofed XFF bypasses
	# the per-IP /wol rate limit and poisons the audit log.
	# Pock sync — per-app JSON blob store (Jqh63/pock, sync/), third service
	# on this VM. Path route on the same vhost (no new vhost/cert); every
	# other path still falls through to the relay below. Same X-Real-IP
	# sanitization (its rate limiter keys on it too).
	handle /pock/* {
		reverse_proxy localhost:8001 {
			header_up -X-Forwarded-For
			header_up X-Real-IP {remote_host}
		}
	}

	# Out-of-band rescue page. When a host-upgrade restarts dockerd on the
	# home server, EVERY containerized access path dies at once — AdGuard
	# (.21, the LAN resolver) and nginx-internal (.20, which serves the
	# *.jqh vhosts) are both containers. A hosts-file entry does NOT help:
	# it resolves to .20, i.e. still a container. So the admin loses access
	# by name AND by wildcard subdomain, while the services themselves are
	# up (OMV's UI is the HOST nginx on :8090, no Docker in the path).
	#
	# This page lists the direct-IP fallbacks. It lives HERE, on the GCP VM,
	# because that is the only piece of the ecosystem with no dependency on
	# the home server: it answers even when the homelab is fully powered off.
	#
	# Served inline via respond (not a file) on purpose: it reuses the
	# existing push-caddyfile + apply routes, so shipping it needs no new
	# sudoers verb and no admin bootstrap on the VM.
	#
	# Everything identifying the private infrastructure is injected from
	# the env file, NOT committed: this repo is public. RESCUE_PATH is the
	# unguessable URL segment (publishing it here would defeat its purpose),
	# RESCUE_HOST the LAN address of the home server, RESCUE_SSH the
	# last-resort shell hint. The public repo therefore carries the page's
	# structure and nothing about the actual topology. Real values live in
	# /etc/caddy/wol-relay.env on the VM, and the canonical URL is recorded
	# in the knowledge-base (wol-relay/README.md) — the recovery copy if the
	# bookmark is ever lost.
	handle /{$RESCUE_PATH} {
		header Content-Type "text/html; charset=utf-8"
		respond `<!DOCTYPE html>
		<html lang="fr">
		<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<meta name="robots" content="noindex,nofollow">
		<title>Accès de secours — homelab</title>
		<style>
		body{font-family:system-ui,sans-serif;margin:0;padding:1.5rem;background:#12151a;color:#e6e8eb;line-height:1.5}
		h1{font-size:1.25rem;margin:0 0 .25rem}
		p.sub{margin:0 0 1.5rem;color:#9aa4b2;font-size:.9rem}
		a.tile{display:block;padding:.9rem 1rem;margin-bottom:.6rem;background:#1c212b;border:1px solid #2b3240;border-radius:10px;color:#e6e8eb;text-decoration:none}
		a.tile:active{background:#242b38}
		.n{font-weight:600}
		.u{color:#7aa2f7;font-size:.85rem;word-break:break-all}
		.note{margin-top:1.5rem;padding:.9rem 1rem;background:#1c212b;border-left:3px solid #e0af68;border-radius:6px;font-size:.85rem;color:#c3cad6}
		</style>
		</head>
		<body>
		<h1>Accès de secours</h1>
		<p class="sub">Accès par IP directe, sans DNS ni conteneur Docker dans le chemin. À utiliser quand un update docker coupe AdGuard et nginx-internal.</p>
		<a class="tile" href="http://{$RESCUE_HOST}:8090"><span class="n">OMV — interface web</span><br><span class="u">http://{$RESCUE_HOST}:8090</span></a>
		<a class="tile" href="http://{$RESCUE_HOST}:3080"><span class="n">Homepage — tableau de bord</span><br><span class="u">http://{$RESCUE_HOST}:3080</span></a>
		<a class="tile" href="http://{$RESCUE_HOST}:8443"><span class="n">code-server</span><br><span class="u">http://{$RESCUE_HOST}:8443</span></a>
		<a class="tile" href="http://{$RESCUE_HOST}:5055"><span class="n">Seerr</span><br><span class="u">http://{$RESCUE_HOST}:5055</span></a>
		<div class="note">
		Ces adresses ne répondent que depuis le LAN ou via WireGuard.<br><br>
		Si rien ne répond : le serveur est éteint (fenêtre d'uptime 13h50-00h10) ou injoignable — réveiller via la PWA WoL.<br><br>
		Ultime recours, sans DNS ni Docker : <b>{$RESCUE_SSH}</b><br><br>
		Hors LAN/WG (un docker down tue aussi WireGuard) : <b>{$RESCUE_OOB}</b>
		</div>
		</body>
		</html>` 200
	}

	reverse_proxy localhost:8000 {
		header_up -X-Forwarded-For
		header_up X-Real-IP {remote_host}
	}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}
}
