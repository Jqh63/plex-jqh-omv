# Caddy process environment file.
# Deploy at /etc/caddy/wol-relay.env on the GCP VM, mode 0640 root:caddy.
# Loaded into the caddy.service environment via the drop-in
# `systemd/caddy.service.d/wol-relay.conf` shipped in this repo.
# The Caddyfile references these variables as {$VAR}.
#
# Never commit a real env file — only this template with placeholders.

# Email for Let's Encrypt account registration. Used by Caddy's
# automatic HTTPS to receive expiry / revocation warnings. Submitted
# to Let's Encrypt at first start; pick an address you actually read.
LE_EMAIL=you@example.com

# Public FQDN that resolves to this VM. Caddy will request a Let's
# Encrypt cert for this name on first start. Must match a DNS A record
# pointing to the VM's public IP.
RELAY_DOMAIN=relay.example.com

# Origin allowed in the CORS Access-Control-Allow-Origin header. Must
# exactly match the scheme + host of the PWA hosting page (e.g.
# https://yourname.github.io — no trailing slash, no path).
CORS_ORIGIN=https://yourname.github.io

# --- Out-of-band rescue page (see the /{$RESCUE_PATH} block in the Caddyfile) ---
# Unguessable URL segment for the rescue page, WITHOUT a leading slash.
# It is the only thing protecting the page, so treat it as a secret: never
# commit the real value, and record it in the knowledge-base so it survives
# a lost bookmark. Generate one with: openssl rand -hex 4
RESCUE_PATH=secours-CHANGEME

# LAN address of the home server. The rescue page links to its direct-IP
# ports (no DNS, no container in the path).
RESCUE_HOST=192.168.0.10

# Last-resort shell hint printed verbatim on the page.
RESCUE_SSH=ssh user@192.168.0.10 -p 22
