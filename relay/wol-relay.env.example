# FastAPI / uvicorn process environment file.
# Deploy at /etc/wol-relay.env on the GCP VM, mode 0640 root:wol.
# Never commit a real env file — only this template with placeholders.

# MAC of the target server, colon-formatted, lowercased on load.
ALLOWED_MAC=AA:BB:CC:DD:EE:FF

# Shared secret sent by the PWA as X-Token header. Generate with:
#   openssl rand -hex 32
# Lives in the PWA URL bookmark as well; treat as a "sensitive bookmark"
# (same risk class as the MAC — leak = anyone can wake the server, but
# only the server, thanks to MAC allowlist).
WOL_TOKEN=REPLACE_WITH_OPENSSL_RAND_HEX_32

# FQDN of the target. Resolved server-side at each /wol call so the
# client cannot redirect packets to an arbitrary IP.
TARGET_HOST=myserver.example.com

# Wake-on-LAN UDP port. Standard is 9 (discard); some setups use 7.
TARGET_PORT=9

# CORS allowed origin is hardcoded in the Caddyfile (via {$CORS_ORIGIN}
# from /etc/caddy/wol-relay.env). No corresponding env var needed in
# this file.
