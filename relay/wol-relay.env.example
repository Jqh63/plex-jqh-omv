# FastAPI / uvicorn process environment file.
# Deploy at /etc/wol-relay.env on the GCP VM, mode 0640 root:wol.
# Never commit a real env file — only this template with placeholders.

# MAC of the target server, colon-formatted, lowercased on load.
ALLOWED_MAC=AA:BB:CC:DD:EE:FF

# Shared secret sent by the PWA as X-Token header. Generate with:
#   openssl rand -hex 32
# Lives in the PWA URL bookmark as well; treat as a "sensitive bookmark"
# (same risk class as the MAC — leak = anyone can wake the server, but
# only the server, thanks to MAC allowlist).
WOL_TOKEN=REPLACE_WITH_OPENSSL_RAND_HEX_32

# FQDN of the target. Resolved server-side at each /wol call so the
# client cannot redirect packets to an arbitrary IP.
TARGET_HOST=myserver.example.com

# Wake-on-LAN UDP port. Standard is 9 (discard); some setups use 7.
TARGET_PORT=9

# CORS allowed origin is hardcoded in the Caddyfile (via {$CORS_ORIGIN}
# from /etc/caddy/wol-relay.env). No corresponding env var needed in
# this file.

# --- Status oracle (v7.0+) ---
#
# Optional. When set, exposes GET /status which returns
# {"up": bool, "stale": bool, "age_s": int} based on a HEAD probe against
# STATUS_TARGET_URL. Cache: fresh < 5 s reuses last verdict, stale 5-60 s
# triggers a re-poll, > 60 s without success expires to up=false.
#
# Pick a URL that returns an HTTP response (any < 500) when the home is
# serving. A DuckDNS wildcard cert covers *.example.duckdns.org but NOT the
# apex — so use an existing subdomain, not the bare apex.
#
# Prefer a path that exercises the SLOWEST user-facing app, not just the host /
# reverse proxy: host-up != app-ready. The host (and a fast app like Plex in
# network_mode: host) can answer while a containerised app (Seerr/Overseerr) is
# still spinning up for ~15 s post-boot — so a target that answers too early flips
# the PWA green and a tapped link lands on an nginx 502/504 gateway. Targeting the
# slow app's readiness endpoint makes "up" mean "the app actually serves" (the
# trade-off: green — and thus every link — waits on that app). A path that hits the
# container (502 while down, < 500 once up) is more reliable than the bare root.
#
# Examples for a SWAG-backed homelab:
#   STATUS_TARGET_URL=https://seerr.example.duckdns.org/api/v1/status   # Overseerr readiness (recommended)
#   STATUS_TARGET_URL=https://plex.example.duckdns.org:32400/identity
#
# Leave unset to disable /status (the PWA falls back to a direct check).
# STATUS_TARGET_URL=

# Tuning knobs (defaults are fine for the family use case):
# STATUS_POLL_FIRST_TIMEOUT_S=3.0   # first attempt — fits a cold TLS handshake after hours of idle
# STATUS_POLL_RETRY_TIMEOUT_S=1.5   # retry attempt — warm socket, ~10× typical RTT
# STATUS_CACHE_FRESH_S=5            # serve cache without re-poll for N s
# STATUS_CACHE_STALE_S=60           # cached "up" expires after N s without success (lower → offline detected faster, e.g. 25)
# ETA_FALLBACK_S=80                 # boot ETA served in /status before any wake is measured

# --- Scheduled-uptime window (v8.12+) ---
#
# Optional. When set, /status responses carry a "window" field the PWA
# adopts automatically: outside this window a down server is shown as a
# calm "En veille" (with the auto-wake time) instead of an alarming
# "Hors ligne". Format HH:MM-HH:MM or HHhMM-HHhMM, may wrap midnight.
# Malformed value = refuses to start (fail-fast at boot).
# UPTIME_WINDOW=13h50-00h10
